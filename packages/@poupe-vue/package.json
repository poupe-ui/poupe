{
  "name": "@poupe/vue",
  "version": "0.6.0",
  "type": "module",
  "description": "Vue component library for Poupe UI framework with theme customization and accessibility support",
  "author": "Alejandro Mery <amery@apptly.co>",
  "license": "MIT",
  "homepage": "https://poupe.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poupe-ui/poupe.git",
    "directory": "packages/@poupe-vue"
  },
  "bugs": {
    "url": "https://github.com/poupe-ui/poupe/issues"
  },
  "keywords": [
    "components",
    "design-system",
    "material-design",
    "material-design-3",
    "poupe",
    "tailwindcss",
    "theming",
    "typescript",
    "ui-library",
    "vue",
    "vue3"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs"
    },
    "./components": {
      "types": "./dist/components.d.ts",
      "import": "./dist/components.mjs"
    },
    "./composables": {
      "types": "./dist/composables.d.ts",
      "import": "./dist/composables.mjs"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "import": "./dist/config.mjs"
    },
    "./resolver": {
      "types": "./dist/resolver.d.ts",
      "import": "./dist/resolver.mjs"
    },
    "./story-viewer": {
      "types": "./dist/story-viewer.d.ts",
      "import": "./dist/story-viewer.mjs"
    },
    "./theme-scheme": {
      "types": "./dist/theme-scheme.d.ts",
      "import": "./dist/theme-scheme.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vite build",
    "clean": "rimraf dist node_modules",
    "dev": "vite",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "precommit": "run-s lint type-check build test",
    "prepack": "eslint --fix package.json && run-s lint:check type-check build test publint",
    "preview": "vite preview",
    "publint": "publint",
    "publish:maybe": "npm view ${npm_package_name}@${npm_package_version} version 2>/dev/null && echo \"${npm_package_name}@${npm_package_version} already published\" || pnpm publish",
    "test": "vitest run",
    "type-check": "vue-tsc --build --force"
  },
  "dependencies": {
    "@iconify-json/material-symbols": "^1.2.65",
    "@iconify-json/svg-spinners": "^1.2.4",
    "@iconify/vue": "^5.0.0",
    "@poupe/tailwindcss": "workspace:^",
    "@poupe/theme-builder": "workspace:^",
    "@unhead/vue": "^2.1.13",
    "@vueuse/core": "^13.9.0",
    "defu": "^6.1.7",
    "reka-ui": "2.3.1",
    "tailwind-merge": "^3.5.0",
    "tailwind-scrollbar": "^4.0.2",
    "tailwind-variants": "^1.0.0",
    "tailwindcss": "^4.1.11",
    "vue": "^3.5.32"
  },
  "devDependencies": {
    "@poupe/eslint-config": "~0.9.1",
    "@tailwindcss/postcss": "^4.1.11",
    "@tailwindcss/vite": "^4.1.11",
    "@tsconfig/node20": "^20.1.9",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^20.19.39",
    "@vitejs/plugin-vue": "^5.2.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.27",
    "eslint": "^9.39.4",
    "jsdom": "^29.0.2",
    "npm-run-all2": "^8.0.4",
    "pathe": "^2.0.3",
    "postcss": "^8.5.9",
    "publint": "^0.3.18",
    "typescript": "~5.9.3",
    "unplugin-vue-components": "^28.8.0",
    "vite": "^6.4.2",
    "vite-plugin-dts": "^4.5.4",
    "vite-plugin-vue-devtools": "^7.7.9",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.12"
  },
  "engines": {
    "node": ">=20.19.2",
    "pnpm": ">=10.33.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "publishConfig": {
    "access": "public"
  }
}
