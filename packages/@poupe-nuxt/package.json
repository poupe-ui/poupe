{
  "name": "@poupe/nuxt",
  "version": "0.4.2",
  "type": "module",
  "description": "Nuxt module for integrating Poupe UI framework with theme customization and components",
  "author": "Alejandro Mery <amery@apptly.co>",
  "license": "MIT",
  "homepage": "https://poupe.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poupe-ui/poupe.git",
    "directory": "packages/@poupe-nuxt"
  },
  "bugs": {
    "url": "https://github.com/poupe-ui/poupe/issues"
  },
  "keywords": [
    "material-design",
    "material-design-3",
    "nuxt",
    "nuxt-module",
    "poupe",
    "tailwindcss",
    "theming",
    "typescript",
    "ui-framework",
    "vue"
  ],
  "main": "./dist/module.mjs",
  "exports": {
    ".": {
      "types": "./dist/types.d.mts",
      "default": "./dist/module.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "run-s build:prepare build:build",
    "build:build": "nuxt-module-build build",
    "build:prepare": "cross-test -s .nuxt/tsconfig.json || run-s build:prepare:stub build:prepare:build",
    "build:prepare:build": "nuxt-module-build prepare",
    "build:prepare:stub": "nuxt-module-build build --stub",
    "clean": "rimraf dist node_modules .nuxt",
    "dev": "nuxi dev playground",
    "dev:build:playground": "nuxi build playground",
    "dev:prepare": "run-s build:prepare:stub build:prepare:build dev:prepare:playground",
    "dev:prepare:playground": "nuxi prepare playground",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "precommit": "run-s dev:prepare lint type-check:check build test",
    "prepack": "eslint --fix package.json && run-s dev:prepare lint:check type-check:check build test publint",
    "publint": "publint",
    "publish:maybe": "npm view ${npm_package_name}@${npm_package_version} version 2>/dev/null && echo \"${npm_package_name}@${npm_package_version} already published\" || pnpm publish",
    "release": "npm run lint && npm run test && npm run prepack && changelogen --release && npm publish && git push --follow-tags",
    "test": "vitest run",
    "test:watch": "vitest watch",
    "type-check": "run-s build:prepare dev:prepare:playground type-check:check",
    "type-check:check": "vue-tsc --noEmit && cd playground && vue-tsc --noEmit"
  },
  "dependencies": {
    "@nuxt/icon": "^1.15.0",
    "@nuxtjs/color-mode": "^3.5.2",
    "@poupe/css": "workspace:^",
    "@poupe/tailwindcss": "workspace:^",
    "@poupe/theme-builder": "workspace:^",
    "@poupe/vue": "workspace:^",
    "@tailwindcss/vite": "^4.1.11",
    "consola": "^3.4.2",
    "std-env": "^3.10.0",
    "stringify-object": "^6.0.0",
    "tailwind-scrollbar": "^4.0.2",
    "tailwindcss": "^4.1.11"
  },
  "devDependencies": {
    "@kagal/cross-test": "~0.1.3",
    "@nuxt/devtools": "^2.7.0",
    "@nuxt/eslint-config": "^1.15.2",
    "@nuxt/kit": "^3.21.2",
    "@nuxt/module-builder": "^1.0.2",
    "@nuxt/schema": "^3.21.2",
    "@nuxt/test-utils": "^3.23.0",
    "@poupe/eslint-config": "~0.9.1",
    "@types/node": "^20.19.39",
    "changelogen": "^0.6.2",
    "defu": "^6.1.7",
    "eslint": "^9.39.4",
    "npm-run-all2": "^8.0.4",
    "nuxt": "^3.21.2",
    "publint": "^0.3.18",
    "typescript": "~5.9.3",
    "unbuild": "3.6.1",
    "vite": "^6.4.2",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.12"
  },
  "engines": {
    "node": ">=20.19.2",
    "pnpm": ">=10.33.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "publishConfig": {
    "access": "public"
  }
}
