{
  "name": "@poupe/css",
  "version": "0.3.1",
  "type": "module",
  "description": "A TypeScript utility library for CSS property manipulation, formatting, and CSS-in-JS operations",
  "author": "Alejandro Mery <amery@apptly.co>",
  "license": "MIT",
  "homepage": "https://github.com/poupe-ui/poupe/tree/main/packages/@poupe-css#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poupe-ui/poupe.git",
    "directory": "packages/@poupe-css"
  },
  "bugs": {
    "url": "https://github.com/poupe-ui/poupe/issues"
  },
  "keywords": [
    "camelCase",
    "case-conversion",
    "css",
    "css-in-js",
    "css-properties",
    "css-rules",
    "css-utilities",
    "formatter",
    "kebab-case",
    "nested-css",
    "poupe",
    "stringify",
    "styling",
    "typescript"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "clean": "rimraf dist node_modules",
    "dev": "vitest watch",
    "dev:prepare": "unbuild --stub",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "precommit": "run-s lint type-check build test",
    "prepack": "eslint --fix package.json && run-s lint:check type-check build test publint",
    "publint": "publint",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "defu": "^6.1.4"
  },
  "devDependencies": {
    "@poupe/eslint-config": "~0.9.1",
    "@types/node": "^20.19.0",
    "eslint": "^9.39.4",
    "npm-run-all2": "^8.0.4",
    "publint": "^0.3.12",
    "typescript": "~5.8.3",
    "unbuild": "3.5.0",
    "vitest": "^3.2.4",
    "vue-tsc": "~2.2.10"
  },
  "engines": {
    "node": ">= 20.19.2",
    "pnpm": ">= 10.10.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "publishConfig": {
    "access": "public"
  }
}
