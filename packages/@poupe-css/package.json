{
  "name": "@poupe/css",
  "version": "0.3.1",
  "type": "module",
  "description": "A TypeScript utility library for CSS property manipulation, formatting, and CSS-in-JS operations",
  "author": "Alejandro Mery <amery@apptly.co>",
  "license": "MIT",
  "homepage": "https://github.com/poupe-ui/poupe/tree/main/packages/@poupe-css#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poupe-ui/poupe.git",
    "directory": "packages/@poupe-css"
  },
  "bugs": {
    "url": "https://github.com/poupe-ui/poupe/issues"
  },
  "keywords": [
    "camelCase",
    "case-conversion",
    "css",
    "css-in-js",
    "css-properties",
    "css-rules",
    "css-utilities",
    "formatter",
    "kebab-case",
    "nested-css",
    "poupe",
    "stringify",
    "styling",
    "typescript"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "clean": "rimraf dist node_modules",
    "dev": "vitest watch",
    "dev:prepare": "unbuild --stub",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "precommit": "run-s lint type-check build test",
    "prepack": "eslint --fix package.json && run-s lint:check type-check build test publint",
    "prepare": "cross-test -s dist/index.mjs || unbuild --stub",
    "publint": "publint",
    "publish:maybe": "npm view ${npm_package_name}@${npm_package_version} version 2>/dev/null && echo \"${npm_package_name}@${npm_package_version} already published\" || pnpm publish",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "defu": "^6.1.4"
  },
  "devDependencies": {
    "@kagal/cross-test": "~0.1.3",
    "@poupe/eslint-config": "~0.9.1",
    "@types/node": "^20.19.0",
    "eslint": "^9.39.4",
    "npm-run-all2": "^8.0.4",
    "publint": "^0.3.12",
    "typescript": "~5.9.3",
    "unbuild": "3.6.1",
    "vitest": "^3.2.4",
    "vue-tsc": "~2.2.10"
  },
  "engines": {
    "node": ">= 20.19.2",
    "pnpm": ">= 10.33.0"
  },
  "packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319",
  "publishConfig": {
    "access": "public"
  }
}
