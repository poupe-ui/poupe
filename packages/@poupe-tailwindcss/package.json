{
  "name": "@poupe/tailwindcss",
  "version": "0.5.0",
  "type": "module",
  "description": "TailwindCSS v4 plugin for Poupe UI framework with theme customization support",
  "author": "Alejandro Mery <amery@apptly.co>",
  "license": "MIT",
  "homepage": "https://poupe.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/poupe-ui/poupe.git",
    "directory": "packages/@poupe-tailwindcss"
  },
  "bugs": {
    "url": "https://github.com/poupe-ui/poupe/issues"
  },
  "keywords": [
    "css",
    "design-system",
    "design-tokens",
    "material-design",
    "material-design-3",
    "poupe",
    "tailwind",
    "tailwindcss",
    "theming",
    "typescript",
    "ui-framework"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "style": "./dist/style.css",
      "import": "./dist/index.mjs"
    },
    "./theme": {
      "types": "./dist/theme.d.ts",
      "import": "./dist/theme.mjs"
    },
    "./utils": {
      "types": "./dist/utils.d.ts",
      "import": "./dist/utils.mjs"
    }
  },
  "style": "./dist/style.css",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "unbuild",
    "clean": "rimraf dist node_modules",
    "dev": "vitest watch",
    "dev:prepare": "unbuild --stub",
    "lint": "eslint --fix .",
    "lint:check": "eslint .",
    "precommit": "run-s lint type-check build test",
    "prepack": "eslint --fix package.json && run-s lint:check type-check build test publint",
    "publint": "publint",
    "test": "vitest run",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@poupe/css": "workspace:^",
    "@poupe/theme-builder": "workspace:^",
    "type-fest": "^4.41.0"
  },
  "devDependencies": {
    "@poupe/eslint-config": "~0.8.4",
    "@tailwindcss/node": "^4.1.11",
    "@types/node": "^20.19.0",
    "eslint": "^9.39.4",
    "pathe": "^2.0.3",
    "publint": "^0.3.12",
    "tailwindcss": "^4.1.11",
    "typescript": "^5.8.3",
    "unbuild": "3.6.1",
    "vitest": "^3.2.4",
    "vue-tsc": "^2.2.10"
  },
  "peerDependencies": {
    "tailwindcss": "^4.1.11"
  },
  "engines": {
    "node": ">=20.19.2",
    "pnpm": ">=10.10.0"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be",
  "publishConfig": {
    "access": "public"
  }
}
